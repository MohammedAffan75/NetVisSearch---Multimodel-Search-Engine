# ── App ──────────────────────────────
APP_ENV=development            # development | production
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Storage ──────────────────────────
STORAGE_BACKEND=local          # local | s3
LOCAL_UPLOAD_DIR=./data/uploads

# ── AWS (only needed when STORAGE_BACKEND=s3) ─
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

# ── Database ─────────────────────────
DB_BACKEND=duckdb              # duckdb | postgres (future)
DUCKDB_PATH=./netvis.duckdb

# ── ML Models ────────────────────────
EMBEDDING_MODEL=jinaai/jina-clip-v2
EMBEDDING_DIM=512
SPACY_MODEL=en_core_web_sm
HF_CACHE_DIR=./model_cache     # local model cache; mount as volume in Docker

# ── Search ───────────────────────────
DEFAULT_TOP_K=10

# ── CORS (comma-separated origins) ───
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
